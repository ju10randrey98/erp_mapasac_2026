generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model permissions {
  id               Int                @id @default(autoincrement())
  code             String             @unique @db.VarChar(100)
  description      String?
  role_permissions role_permissions[]
}

model role_permissions {
  role_id       Int
  permission_id Int
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

model roles {
  id               Int                @id @default(autoincrement())
  name             String             @unique @db.VarChar(50)
  description      String?
  role_permissions role_permissions[]
  user_roles       user_roles[]
}

model user_roles {
  user_id String @db.Uuid
  role_id Int

  roles roles @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, role_id])
}

model users {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username             String    @unique @db.VarChar(50)
  email                String    @unique @db.VarChar(100)
  full_name            String?   @db.VarChar(150)
  password_hash        String
  is_active            Boolean   @default(true)
  must_change_password Boolean   @default(false)
  last_login_at        DateTime? @db.Timestamp(6)
  created_at           DateTime  @default(now()) @db.Timestamp(6)
  updated_at           DateTime  @default(now()) @db.Timestamp(6)
  failed_attempts      Int       @default(0)
  locked_until         DateTime? @db.Timestamp(6)

  user_roles user_roles[]

  // relaciones inversas para audit_logs (importante para Prisma)
  audit_logs_as_actor  audit_logs[] @relation("audit_actor")
  audit_logs_as_target audit_logs[] @relation("audit_target")
}

model clients {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String?  @unique @db.VarChar(30)
  name       String   @db.VarChar(200)
  doc_type   String?  @db.VarChar(10)
  doc_number String?  @db.VarChar(30)
  email      String?  @db.VarChar(120)
  phone      String?  @db.VarChar(30)
  address    String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
}

model products {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku         String   @unique @db.VarChar(50)
  name        String   @db.VarChar(150)
  description String?
  unit        String   @default("UND") @db.VarChar(20)
  price       Decimal? @db.Decimal(12, 2)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)

  inventory_stock     inventory_stock[]
  inventory_movements inventory_movements[]
}

model warehouses {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String   @unique @db.VarChar(30)
  name       String   @db.VarChar(150)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  inventory_stock     inventory_stock[]
  inventory_movements inventory_movements[]
}

model inventory_stock {
  product_id   String  @db.Uuid
  warehouse_id String  @db.Uuid
  qty          Decimal @default(0) @db.Decimal(14, 3)

  products   products   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  warehouses warehouses @relation(fields: [warehouse_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([product_id, warehouse_id])
  @@index([warehouse_id], map: "idx_inventory_stock_warehouse")
}

model inventory_movements {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id   String   @db.Uuid
  warehouse_id String   @db.Uuid

  qty           Decimal? @db.Decimal(12, 2)
  movement_type String
  created_at    DateTime @default(now()) @db.Timestamp(6)

  products   products   @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
  warehouses warehouses @relation(fields: [warehouse_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([product_id])
  @@index([warehouse_id])
}

model audit_logs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action     String   @db.VarChar(50)
  actor_id   String?  @db.Uuid
  target_id  String?  @db.Uuid
  ip         String?
  user_agent String?
  details    Json?
  created_at DateTime @default(now()) @db.Timestamp(6)

  actor  users? @relation("audit_actor", fields: [actor_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  target users? @relation("audit_target", fields: [target_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([action, created_at])
  @@index([actor_id, created_at])
  @@index([target_id, created_at])
}